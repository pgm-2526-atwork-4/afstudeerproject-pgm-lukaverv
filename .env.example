# Database Connection
# Get database URL from Neon.tech or your PostgreSQL provider
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# Application URL
# For local development, use http://localhost:3000
# For production, use your deployed domain
BASE_URL="http://localhost:3000"

# JWT Secret for manual authentication
# Generate a secure random string with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="your-jwt-secret-key-here"

# NextAuth Configuration
# For local: http://localhost:3000/api/auth
# For production: https://yourdomain.com/api/auth
NUXT_AUTH_ORIGIN="http://localhost:3000/api/auth"

# NextAuth Secret
# Generate with: openssl rand -base64 32
NUXT_AUTH_SECRET="your-nextauth-secret-here"

# Cloudinary Configuration
# Get these from your Cloudinary dashboard
NUXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NUXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# GitHub OAuth
# Create OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth
# Create OAuth app at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email Configuration (Gmail SMTP)
# For Gmail, use an app-specific password: https://myaccount.google.com/apppasswords
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-specific-password"

# Stripe Configuration
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-secret-key"

# Stripe Webhook Secret
# Get this from: https://dashboard.stripe.com/webhooks
# After creating a webhook endpoint, copy the signing secret
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
